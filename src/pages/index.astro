---
import { getEmDashCollection, getSiteSettings } from "emdash";
import { Image } from "emdash/ui";
import Base from "../layouts/Base.astro";
import { resolveBlogSiteIdentity } from "../utils/site-identity";

const { siteTitle } = resolveBlogSiteIdentity(await getSiteSettings());
const seoTitle = `${siteTitle} | Agencia de desarrollo web`;
const seoDescription =
	"webgae disena y desarrolla sitios web rapidos, claros y orientados a resultados para negocios digitales.";

const { entries: posts, cacheHint } = await getEmDashCollection("posts");
Astro.cache.set(cacheHint);

const featuredProjects = posts
	.toSorted((a, b) => {
		const dateA = a.data.publishedAt?.getTime() ?? 0;
		const dateB = b.data.publishedAt?.getTime() ?? 0;
		return dateB - dateA;
	})
	.slice(0, 3);
---

<Base title={seoTitle} description={seoDescription}>
	<nav class="page-nav">
		<a href="#servicios">Servicios</a>
		<a href="#proceso">Proceso</a>
		<a href="#proyectos">Proyectos</a>
	</nav>

	<section class="hero">
		<div class="hero-copy">
			<p class="eyebrow">Agencia digital</p>
			<h1>
				Desarrollo web para marcas que quieren vender mas y verse mejor.
			</h1>
			<p class="lead">
				En webgae creamos webs corporativas, landings y plataformas a medida
				con foco en velocidad, SEO y conversion.
			</p>
			<div class="hero-cta">
				<a href="/contacto" class="btn btn-primary">Solicitar propuesta</a>
				<a href="/posts" class="btn btn-ghost">Ver proyectos</a>
			</div>
		</div>
		<div class="hero-card">
			<p class="card-title">Enfoque de trabajo</p>
			<ul>
				<li>Discovery y estrategia</li>
				<li>UX/UI con prototipos reales</li>
				<li>Desarrollo con stack moderno</li>
				<li>SEO tecnico y rendimiento</li>
			</ul>
		</div>
	</section>

	<section class="services" id="servicios">
		<header class="section-head">
			<p class="eyebrow">Servicios</p>
			<h2>Todo lo necesario para lanzar y escalar tu presencia digital</h2>
		</header>
		<div class="services-grid">
			<article>
				<h3>Web corporativa</h3>
				<p>
					Sitios claros y profesionales para comunicar tu propuesta de valor y
					generar confianza.
				</p>
			</article>
			<article>
				<h3>Landing de conversion</h3>
				<p>
					Paginas enfocadas en captar leads o ventas con copy, estructura y
					velocidad optimizadas.
				</p>
			</article>
			<article>
				<h3>Ecommerce y producto</h3>
				<p>
					Implementacion de tiendas y plataformas con arquitectura solida para
					crecer sin friccion.
				</p>
			</article>
		</div>
	</section>

	<section class="process" id="proceso">
		<header class="section-head">
			<p class="eyebrow">Metodo</p>
			<h2>Un proceso simple, medible y sin humo</h2>
		</header>
		<ol class="steps">
			<li>
				<span>01</span>
				<div>
					<h3>Analisis</h3>
					<p>Objetivos, competencia y mapa de contenidos.</p>
				</div>
			</li>
			<li>
				<span>02</span>
				<div>
					<h3>Diseno</h3>
					<p>Wireframes y diseno visual con enfoque en conversion.</p>
				</div>
			</li>
			<li>
				<span>03</span>
				<div>
					<h3>Desarrollo</h3>
					<p>Codigo limpio, rendimiento alto y SEO tecnico desde base.</p>
				</div>
			</li>
			<li>
				<span>04</span>
				<div>
					<h3>Lanzamiento</h3>
					<p>Publicacion, medicion y roadmap de mejoras continuas.</p>
				</div>
			</li>
		</ol>
	</section>

	<section class="projects" id="proyectos">
		<header class="section-head">
			<p class="eyebrow">Proyectos recientes</p>
			<h2>Resultados reales en experiencias web reales</h2>
		</header>
		{
			featuredProjects.length === 0 ? (
				<p class="empty-projects">
					Aun no hay proyectos publicados. Publica contenido desde el panel para
					mostrar casos aqui.
				</p>
			) : (
				<div class="project-grid">
					{featuredProjects.map((project) => (
						<a href={`/posts/${project.id}`} class="project-card">
							{project.data.featured_image && (
								<div class="project-media">
									<Image image={project.data.featured_image} />
								</div>
							)}
							<div class="project-copy">
								<h3>{project.data.title}</h3>
								<p>{project.data.excerpt || "Ver detalle del proyecto"}</p>
							</div>
						</a>
					))}
				</div>
			)
		}
	</section>
</Base>

<style>
	.page-nav {
		display: flex;
		justify-content: center;
		gap: var(--spacing-6);
		padding: var(--spacing-4);
		background: var(--color-bg-subtle);
		border-bottom: 1px solid var(--color-border-subtle);
		font-size: var(--font-size-sm);
		font-weight: 500;
	}

	.page-nav a {
		color: var(--color-text-secondary);
		text-decoration: none;
		transition: color var(--transition-fast);
	}

	.page-nav a:hover {
		color: var(--color-text);
	}

	.hero,
	.services,
	.process,
	.projects {
		max-width: var(--wide-width);
		margin: 0 auto;
		padding: var(--spacing-12) var(--spacing-6);
	}

	.hero {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: var(--spacing-8);
		align-items: stretch;
		padding-top: var(--spacing-16);
	}

	.hero-copy h1 {
		font-size: clamp(2rem, 5vw, 3.8rem);
		line-height: 1.04;
		max-width: 16ch;
		margin-top: var(--spacing-3);
	}

	.lead {
		font-size: var(--font-size-lg);
		color: var(--color-text-secondary);
		max-width: 56ch;
		margin-top: var(--spacing-4);
	}

	.eyebrow {
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: var(--tracking-wider);
		color: var(--color-muted);
	}

	.hero-cta {
		display: flex;
		gap: var(--spacing-3);
		margin-top: var(--spacing-6);
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-3) var(--spacing-5);
		border-radius: var(--radius-lg);
		font-weight: 600;
		text-decoration: none;
	}

	.btn-primary {
		background: #0c0f1d;
		color: #ffffff;
	}

	.btn-primary:hover {
		background: #1d2a68;
		color: #ffffff;
	}

	.btn-ghost {
		background: transparent;
		color: var(--color-text);
		border: 1px solid var(--color-border);
	}

	.btn-ghost:hover {
		background: var(--color-surface);
		color: var(--color-text);
	}

	.hero-card {
		border: 1px solid var(--color-border);
		border-radius: 18px;
		background: radial-gradient(
			circle at top right,
			#f6f8ff 0%,
			var(--color-bg) 70%
		);
		padding: var(--spacing-6);
	}

	:root.dark .hero-card {
		background: radial-gradient(
			circle at top right,
			rgba(75, 110, 255, 0.14) 0%,
			var(--color-bg) 72%
		);
	}

	.card-title {
		font-weight: 600;
		margin-bottom: var(--spacing-4);
	}

	.hero-card ul {
		display: grid;
		gap: var(--spacing-3);
		list-style: none;
		padding: 0;
	}

	.hero-card li {
		padding-bottom: var(--spacing-2);
		border-bottom: 1px solid var(--color-border-subtle);
	}

	.section-head h2 {
		margin-top: var(--spacing-2);
		font-size: clamp(1.5rem, 3.2vw, 2.4rem);
		max-width: 24ch;
	}

	.services-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-4);
		margin-top: var(--spacing-6);
	}

	.services-grid article {
		padding: var(--spacing-5);
		border: 1px solid var(--color-border);
		border-radius: 14px;
		background: var(--color-bg-subtle);
	}

	.services-grid h3 {
		margin-bottom: var(--spacing-3);
	}

	.services-grid p {
		color: var(--color-text-secondary);
	}

	.steps {
		list-style: none;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: var(--spacing-4);
		margin-top: var(--spacing-6);
		padding: 0;
	}

	.steps li {
		display: flex;
		gap: var(--spacing-4);
		padding: var(--spacing-5);
		border-radius: 14px;
		border: 1px solid var(--color-border);
	}

	.steps span {
		font-size: var(--font-size-sm);
		font-weight: 700;
		color: #1d2a68;
	}

	:root.dark .steps span {
		color: #9ab0ff;
	}

	.steps p {
		margin-top: var(--spacing-2);
		color: var(--color-text-secondary);
	}

	.project-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--spacing-4);
		margin-top: var(--spacing-6);
	}

	.project-card {
		display: block;
		border: 1px solid var(--color-border);
		border-radius: 14px;
		overflow: hidden;
		background: var(--color-bg);
		color: var(--color-text);
	}

	.project-card:hover {
		color: var(--color-text);
		border-color: var(--color-accent);
	}

	.project-media img {
		width: 100%;
		height: auto;
		aspect-ratio: 16 / 10;
		object-fit: cover;
	}

	.project-copy {
		padding: var(--spacing-5);
	}

	.project-copy h3 {
		margin-bottom: var(--spacing-2);
	}

	.project-copy p,
	.empty-projects {
		color: var(--color-text-secondary);
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
		}

		.services-grid,
		.project-grid {
			grid-template-columns: 1fr 1fr;
		}

		.steps {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 640px) {
		.hero,
		.services,
		.process,
		.projects {
			padding: var(--spacing-8) var(--spacing-4);
		}

		.services-grid,
		.project-grid {
			grid-template-columns: 1fr;
		}

		.hero-cta {
			flex-direction: column;
		}
	}
</style>

